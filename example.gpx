<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1"
     creator="Knooppunten App"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">

  <metadata>
    <name>Voorbeeld knooppunten route – Veluwe</name>
    <desc>Een voorbeeld GPX bestand met knooppunten voor gebruik in de Knooppunten app.</desc>
  </metadata>

  <!-- Knooppunten as waypoints -->
  <wpt lat="52.0762" lon="5.8521">
    <name>1</name>
    <desc>Knooppunt 1</desc>
  </wpt>
  <wpt lat="52.0890" lon="5.8643">
    <name>5</name>
    <desc>Knooppunt 5</desc>
  </wpt>
  <wpt lat="52.1012" lon="5.8754">
    <name>23</name>
    <desc>Knooppunt 23</desc>
  </wpt>
  <wpt lat="52.1134" lon="5.8865">
    <name>44</name>
    <desc>Knooppunt 44</desc>
  </wpt>
  <wpt lat="52.1256" lon="5.8976">
    <name>67</name>
    <desc>Knooppunt 67</desc>
  </wpt>

  <!-- Track following the route between the knooppunten -->
  <trk>
    <name>Voorbeeld route</name>
    <trkseg>
      <trkpt lat="52.0762" lon="5.8521"><ele>20</ele></trkpt>
      <trkpt lat="52.0790" lon="5.8550"><ele>22</ele></trkpt>
      <trkpt lat="52.0820" lon="5.8580"><ele>24</ele></trkpt>
      <trkpt lat="52.0850" lon="5.8610"><ele>23</ele></trkpt>
      <trkpt lat="52.0890" lon="5.8643"><ele>21</ele></trkpt>
      <trkpt lat="52.0920" lon="5.8670"><ele>20</ele></trkpt>
      <trkpt lat="52.0950" lon="5.8700"><ele>22</ele></trkpt>
      <trkpt lat="52.0980" lon="5.8730"><ele>25</ele></trkpt>
      <trkpt lat="52.1012" lon="5.8754"><ele>28</ele></trkpt>
      <trkpt lat="52.1040" lon="5.8780"><ele>26</ele></trkpt>
      <trkpt lat="52.1070" lon="5.8810"><ele>24</ele></trkpt>
      <trkpt lat="52.1100" lon="5.8840"><ele>22</ele></trkpt>
      <trkpt lat="52.1134" lon="5.8865"><ele>20</ele></trkpt>
      <trkpt lat="52.1160" lon="5.8890"><ele>21</ele></trkpt>
      <trkpt lat="52.1190" lon="5.8920"><ele>23</ele></trkpt>
      <trkpt lat="52.1220" lon="5.8950"><ele>25</ele></trkpt>
      <trkpt lat="52.1256" lon="5.8976"><ele>24</ele></trkpt>
    </trkseg>
  </trk>

</gpx>
